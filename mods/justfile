# Shared mod build layout and recipes (mod-level).
# Child mods/<name>/justfile must set: mod, unpack_paths (list of PAK paths)
# Optional: tojson_exclude, uexp_signatures (lists), merge_extracted, fromjson_inplace, fromjson_workers, fromjson_max_retries

import '../justfile'

merge_extracted := "false"
fromjson_inplace := "false"
fromjson_workers := ""
fromjson_max_retries := ""

mod_build := build_dir + "/" + mod
mod_extracted := mod_build + "/extracted"
mod_json := mod_build + "/json"

[script("powershell", "-NoProfile", "-ExecutionPolicy", "Bypass")]
_ensure-json:
    $ErrorActionPreference = 'Stop'
    $tag = '{{mod}}'
    $json = '{{mod_json}}'
    $count = 0
    if (Test-Path -LiteralPath $json) {
        $count = @(Get-ChildItem -Path $json -Filter '*.json' -Recurse -File -ErrorAction SilentlyContinue).Count
    }
    if ($count -gt 0) {
        Write-Host "[${tag}:ensure-json] ok ($count files in $json)"
        return
    }
    Write-Host "[${tag}:ensure-json] missing — running: just mod $tag tojson"
    & '{{just_exe}}' mod $tag tojson
    if ($LASTEXITCODE -ne 0) { throw "just mod $tag tojson failed with exit code $LASTEXITCODE" }
    $count = @(Get-ChildItem -Path $json -Filter '*.json' -Recurse -File -ErrorAction SilentlyContinue).Count
    if ($count -eq 0) { throw "No JSON in $json after tojson" }
    Write-Host "[${tag}:ensure-json] ok ($count files in $json)"

[doc("repak unpack mod paths to build/MOD/extracted/")]
[script("powershell", "-NoProfile", "-ExecutionPolicy", "Bypass")]
unpack: fetch-repak extract-aes-key
    $ErrorActionPreference = 'Stop'
    $tag = '{{mod}}'
    Write-Host "[${tag}:unpack] starting..."
    $repakExe = '{{repak}}'
    $pakPath = '{{game_pak}}'
    $aesKey = '{{aes_key}}'
    $outDir = '{{mod_extracted}}'
    if (-not (Test-Path -LiteralPath $pakPath)) {
        throw "PAK not found: $pakPath"
    }
    if (Test-Path -LiteralPath $outDir) {
        Write-Host "[${tag}:unpack] removing existing $outDir"
        Remove-Item -LiteralPath $outDir -Recurse -Force
    }
    New-Item -ItemType Directory -Force -Path $outDir | Out-Null
    $includes = @('{{ join_list(unpack_paths) }}'.Split(' ', [System.StringSplitOptions]::RemoveEmptyEntries))
    if (-not $includes.Count) {
        throw "No unpack paths configured (set unpack_paths in mods/{{mod}}/justfile)"
    }
    Write-Host "[${tag}:unpack] includes=$($includes -join ', ')"
    $repakArgs = @('--aes-key', $aesKey, 'unpack', '--output', $outDir)
    foreach ($inc in $includes) {
        $repakArgs += @('--include', $inc)
    }
    $repakArgs += $pakPath
    & $repakExe @repakArgs
    if ($LASTEXITCODE -ne 0) { throw "repak unpack failed with exit code $LASTEXITCODE" }
    Write-Host "[${tag}:unpack] wrote $outDir"

[script("powershell", "-NoProfile", "-ExecutionPolicy", "Bypass")]
_tojson:
    $ErrorActionPreference = 'Stop'
    $tag = '{{mod}}'
    Write-Host "[${tag}:tojson] starting..."
    Push-Location '{{root}}'
    try {
        $args = @(
            'run', 'python', 'scripts/convert.py', 'tojson',
            '{{mod_extracted}}', '{{mod_json}}',
            '--uassetgui', '{{uassetgui}}',
            '--version', '{{ue_version}}',
            '--usmap', '{{usmap}}',
            '--skip-existing', '-w', '{{workers}}'
        )
        $exclude = @('{{ join_list(tojson_exclude) }}'.Split(' ', [System.StringSplitOptions]::RemoveEmptyEntries))
        foreach ($pattern in $exclude) {
            if ($pattern) { $args += @('--exclude', $pattern) }
        }
        & '{{uv}}' @args
        if ($LASTEXITCODE -ne 0) { throw "convert.py tojson failed with exit code $LASTEXITCODE" }
    } finally {
        Pop-Location
    }

[doc("UAssetGUI convert uassets to build/MOD/json/ (needs extract-usmap once)")]
tojson: unpack extract-usmap fetch-uassetgui _tojson

# Override `_clean-extra` in mods/<name>/justfile for generated assets, caches, etc.
[private]
_clean-extra:
    @exit 0

[doc("Remove build/MOD/ and run mod-specific _clean-extra")]
[script("powershell", "-NoProfile", "-ExecutionPolicy", "Bypass")]
clean: _clean-extra
    $ErrorActionPreference = 'Stop'
    $tag = '{{mod}}'
    $dir = '{{mod_build}}'
    if (Test-Path -LiteralPath $dir) {
        Remove-Item -LiteralPath $dir -Recurse -Force
        Write-Host "[${tag}:clean] removed $dir"
    } else {
        Write-Host "[${tag}:clean] no build dir: $dir"
    }
